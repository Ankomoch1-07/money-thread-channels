# build artifacts
**/out/*.mp4
**/out/*.wav
**/out/timeline.json
**/out/graph/
core/remotion/node_modules/
node_modules/

# Remotion public: 静的素材(irasutoya/se/軽いbg動画≤30MB)はCIで使うので追跡する。
# 生成物(per-ep staging=voice/timeline/graph)・theme・重い背景(>30MB)はローカルのみ。
core/remotion/public/*/theme.json
core/remotion/public/*/*/voice.wav
core/remotion/public/*/*/timeline.json
core/remotion/public/*/*/graph/
core/remotion/public/*/bg/*.mov
core/remotion/public/channel_04_gold/bg/gold_02.mp4
core/remotion/public/channel_04_gold/bg/gold_03.mp4
core/remotion/public/channel_04_gold/bg/gold_04.mp4
core/remotion/public/channel_04_gold/bg/gold_05.mp4
**/.DS_Store
!core/remotion/public/.gitkeep

# secrets / auth
**/client_secret.json
**/token.json
.env

# ingest runtime output (regenerated)
channels/*/ingest.json

# python
__pycache__/
*.pyc

# keep empty dirs
!**/scripts/.gitkeep
!**/out/.gitkeep

# slot_fill の充填済みプロンプト（生成物）
**/out/*.prompt.txt

# 自動生成台本（実行時生成物）。手書きfixtureのep_test01のみ追跡
channels/*/scripts/*.txt
!channels/*/scripts/ep_test01.txt
# topic_ledgerは実行時状態
channels/*/topic_ledger.json

# out/配下は全て生成物（voice.wav/wav/timeline/graph/subs/prompt）
channels/*/out/*
!channels/*/out/.gitkeep
