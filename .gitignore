# build artifacts
**/out/*.mp4
**/out/*.wav
**/out/timeline.json
**/out/graph/
core/remotion/node_modules/
node_modules/

# Remotion public は生成物（プレースホルダ素材/run.shが配置したtheme・timeline・graph）。
# 実素材/背景も含めコミットしない（procure or generate で再現）。
core/remotion/public/*/
!core/remotion/public/.gitkeep

# secrets / auth
**/client_secret.json
**/token.json
.env

# ingest runtime output (regenerated)
channels/*/ingest.json

# python
__pycache__/
*.pyc

# keep empty dirs
!**/scripts/.gitkeep
!**/out/.gitkeep

# slot_fill の充填済みプロンプト（生成物）
**/out/*.prompt.txt

# 自動生成台本（実行時生成物）。手書きfixtureのep_test01のみ追跡
channels/*/scripts/*.txt
!channels/*/scripts/ep_test01.txt
# topic_ledgerは実行時状態
channels/*/topic_ledger.json

# out/配下は全て生成物（voice.wav/wav/timeline/graph/subs/prompt）
channels/*/out/*
!channels/*/out/.gitkeep
